[flake8]
max-line-length = 100
max-doc-length = 100
extend-ignore =
    E203,
    W503,
    W504,
    S101,
exclude =
    .venv,
    .git,
    __pycache__,
    db,
    specs,
    .specify,
    *.egg-info
per-file-ignores =
    app.py: ANN001,ANN002,ANN003,ANN201,ANN202
statistics = True
count = True
