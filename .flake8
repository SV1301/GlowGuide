[flake8]
max-line-length = 100
max-doc-length = 100
extend-ignore =
    # handled by ruff/pylint or intentional
    E203,  # whitespace before ':'  (Black/Ruff compatible)
    W503,  # line break before binary operator
    W504,  # line break after binary operator
    S101,  # assert (acceptable outside security boundaries)
exclude =
    .venv,
    .git,
    __pycache__,
    db,
    specs,
    .specify,
    *.egg-info
per-file-ignores =
    # UI entry-point — relax annotation checks
    app.py: ANN001,ANN002,ANN003,ANN201,ANN202
statistics = True
count = True
